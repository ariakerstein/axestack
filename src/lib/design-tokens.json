    "searchField": {
      "background": "surface-700",
      "focusRing": "primary-400",
      "focusRingWidth": "1px"
    },
    "statusBadge": {
      "textColor": "text-high",
      "fontSize": "xs",
      "fontWeight": "bold",
      "textTransform": "uppercase"
    },
    "icon": {
      "size": "24px",
      "touchArea": "44px"
    },
    "container": {
      "maxWidth": "1200px",
      "padding": "16px"
    }
  },
  "accessibility": {
    "minContrastRatio": 4.5,
    "minTouchTarget": "44px",
    "focusRingWidth": "2px",
    "focusRingColor": "action-500"
